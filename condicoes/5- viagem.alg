algoritmo "vaigem"

var
 dinheiro: inteiro

inicio

  escreval("quanto voce tem de dinheiro?  ")
  leia(dinheiro)
   

   se(dinheiro>= 10000)entao
    escreval("irei a dysney")
  senao
    se(dinheiro >= 5000)entao
      escreval("irei visitar minha cidade natal")
    senao
    escreval("irei ficar em casa!")
    fimse
  fimse

fimalgoritmo
